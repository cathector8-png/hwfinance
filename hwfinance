def handle_calc_multiple(args, data_list):
    headers = ["Ticker"]
    alignments = ["L"]
    show_all = (args.calc == 'all')
    
    if show_all or args.calc == 'fcf':
        headers.append("Avg FCF")
        alignments.append("R")
    if show_all or args.calc == 'ev':
        headers.append("EV")
        alignments.append("R")
    if show_all or args.calc == 'fcf-yield':
        headers.append("FCF Yield")
        alignments.append("R")
    if show_all or args.calc == 'multiples':
        headers.append("P/FCF")
        alignments.append("R")
        headers.append("EV/EBITDA")
        alignments.append("R")
        headers.append("Net Debt/EBITDA")
        alignments.append("R")
    if show_all or args.calc == 'dcf':
        headers.append("Growth Rate")
        alignments.append("R")
        headers.append("CAPM discount")
        alignments.append("R")
        headers.append("Implied EV")
        alignments.append("R")
        headers.append("Intrinsic Price")
        alignments.append("R")
        
    rows = []
    for data in data_list:
        cs = data['currency_symbol']
        ev = data['market_cap'] + data['total_debt'] - data['cash']
        net_debt = data['total_debt'] - data['cash']
        fcf_yield = (data['fcf'] / data['market_cap']) if data['market_cap'] > 0 else 0.0
        p_fcf = (data['market_cap'] / data['fcf']) if data['fcf'] > 0 else 0.0
        ev_ebitda = (ev / data['ebitda']) if data['ebitda'] > 0 else 0.0
        nd_ebitda = (net_debt / data['ebitda']) if data['ebitda'] > 0 else 0.0
        
        rf = 0.040
        erp = 0.055
        discount_rate = max(0.05, min(rf + (data['beta'] * erp), 0.15))
        
        projected_fcf = data['fcf']
        high_growth = data['revenue_growth']
        terminal_growth = 0.025
        
        present_value_fcf = 0.0
        for year in range(1, 6):
            projected_fcf *= (1 + high_growth)
            present_value_fcf += projected_fcf / ((1 + discount_rate) ** year)
            
        current_growth = high_growth
        for year in range(6, 11):
            current_growth -= (high_growth - terminal_growth) / 5
            projected_fcf *= (1 + current_growth)
            present_value_fcf += projected_fcf / ((1 + discount_rate) ** year)
            
        terminal_value = (projected_fcf * (1 + terminal_growth)) / (discount_rate - terminal_growth)
        terminal_value_pv = terminal_value / ((1 + discount_rate) ** 10)
        
        dcf_enterprise_value = present_value_fcf + terminal_value_pv
        dcf_equity_value = dcf_enterprise_value - data['total_debt'] + data['cash']
        # FIX: Guard against zero shares outstanding
        so_shares = data['shares_outstanding'] if data['shares_outstanding'] > 0 else 1.0
        intrinsic_value_per_share = max(0.0, dcf_equity_value / so_shares)
        
        row = [data['symbol']]
        if show_all or args.calc == 'fcf':
            row.append(f"{cs}{data['fcf']:,.0f}")
        if show_all or args.calc == 'ev':
            row.append(f"{cs}{ev:,.0f}")
        if show_all or args.calc == 'fcf-yield':
            row.append(f"{fcf_yield * 100:.2f}%")
        if show_all or args.calc == 'multiples':
            row.append(f"{p_fcf:.2f}x" if p_fcf > 0 else "N/A")
            row.append(f"{ev_ebitda:.2f}x" if ev_ebitda > 0 else "N/A")
            row.append(f"{nd_ebitda:.2f}x" if data['ebitda'] > 0 else "N/A")
        if show_all or args.calc == 'dcf':
            row.append(f"{high_growth * 100:.2f}%")
            row.append(f"{discount_rate * 100:.2f}%")
            row.append(f"{cs}{dcf_enterprise_value:,.0f}")
            row.append(f"{cs}{intrinsic_value_per_share:,.2f}")
        rows.append(row)
        
    format_output(headers, rows, alignments, args.format)

