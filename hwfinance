def handle_calc(args, data):
    # Basic core valuations
    ev = data['market_cap'] + data['total_debt'] - data['cash']
    net_debt = data['total_debt'] - data['cash']
    fcf_yield = (data['fcf'] / data['market_cap']) if data['market_cap'] > 0 else 0.0
    p_fcf = (data['market_cap'] / data['fcf']) if data['fcf'] > 0 else 0.0
    ev_ebitda = (ev / data['ebitda']) if data['ebitda'] > 0 else 0.0
    nd_ebitda = (net_debt / data['ebitda']) if data['ebitda'] > 0 else 0.0
    
    # Capital Asset Pricing Model (CAPM) Cost of Equity
    rf = 0.040     # Baseline 10-Year Treasury Yield
    erp = 0.055    # Equity Risk Premium Baseline
    discount_rate = max(0.05, min(rf + (data['beta'] * erp), 0.15)) # Floor at 5%, Cap at 15%
    
    # Two-Stage DCF Valuation Runway Core (Years 1-10)
    present_value_fcf = 0.0
    projected_fcf = data['fcf']
    high_growth = data['revenue_growth']
    terminal_growth = 0.025 # Baseline GDP tracking proxy
    
    # Phase 1: High Growth Runway Phase (Years 1-5)
    for year in range(1, 6):
        projected_fcf *= (1 + high_growth)
        present_value_fcf += projected_fcf / ((1 + discount_rate) ** year)
        
    # Phase 2: Deceleration Fade Stage (Years 6-10)
    current_growth = high_growth
    for year in range(6, 11):
        current_growth -= (high_growth - terminal_growth) / 5
        projected_fcf *= (1 + current_growth)
        present_value_fcf += projected_fcf / ((1 + discount_rate) ** year)
        
    # Terminal Value Formulation via Gordon Growth at Year 10
    terminal_value = (projected_fcf * (1 + terminal_growth)) / (discount_rate - terminal_growth)
    terminal_value_pv = terminal_value / ((1 + discount_rate) ** 10)
    
    # Derive Implied Values
    dcf_enterprise_value = present_value_fcf + terminal_value_pv
    dcf_equity_value = dcf_enterprise_value - data['total_debt'] + data['cash']
    intrinsic_value_per_share = max(0.0, dcf_equity_value / data['shares_outstanding'])

    if args.json:
        calc_out = {
            "enterprise_value": ev, "net_debt": net_debt, "fcf_yield": fcf_yield, "price_to_fcf": p_fcf,
            "ev_ebitda": ev_ebitda, "net_debt_ebitda": nd_ebitda, "capm_discount_rate": discount_rate,
            "dcf_enterprise_value": dcf_enterprise_value, "intrinsic_value_per_share": intrinsic_value_per_share
        }
        print(json.dumps({**data, **calc_out}, indent=4))
        return

    print_table_header("HWFINANCE", data['symbol'], data['display_currency'], data['fallback_triggered'], data['proxy_used'])
    show_all = (args.calc == 'all')
    cs = data['currency_symbol']

    if show_all or args.calc == 'fcf': 
        print_table_row("Smoothed Avg FCF (Historical)", f"{cs}{data['fcf']:,.0f}")
    if show_all or args.calc == 'ev': 
        print_table_row("Enterprise Value (EV)", f"{cs}{ev:,.0f}")
    if show_all or args.calc == 'fcf-yield': 
        print_table_row("Free Cash Flow Yield", f"{fcf_yield * 100:.2f}%")
    if show_all or args.calc == 'multiples':
        print_table_row("Price / FCF Multiples", f"{p_fcf:.2f}x" if p_fcf > 0 else "N/A")
        print_table_row("EV / EBITDA Multiples", f"{ev_ebitda:.2f}x" if ev_ebitda > 0 else "N/A")
        print_table_row("Net Debt / EBITDA Ratio", f"{nd_ebitda:.2f}x" if data['ebitda'] > 0 else "N/A")
    if show_all or args.calc == 'dcf': 
        print_table_row("Calculated Growth Runway Rate", f"{high_growth * 100:.2f}%")
        print_table_row("Dynamic Cost of Equity (CAPM)", f"{discount_rate * 100:.2f}%")
        print_table_row("2-Stage Implied Enterprise Val", f"{cs}{dcf_enterprise_value:,.0f}")
        print_table_row("Intrinsic Target Price/Sh", f"{cs}{intrinsic_value_per_share:,.2f}")
    print_table_footer()

CONFIG_PATH = os.path.expanduser("~/.hwfinance_config.json")

def load_config():
    if os.path.exists(CONFIG_PATH):
        try:
            with open(CONFIG_PATH, 'r') as f:
                return json.load(f)
        except:
            return {}
    return {}

def save_config(config):
    try:
        with open(CONFIG_PATH, 'w') as f:
            json.dump(config, f, indent=4)
        print(f"{C_GREEN}SUCCESS:{C_RESET} Configuration saved to {CONFIG_PATH}")
    except Exception as e:
        print(f"{C_RED}ERROR:{C_RESET} Failed to save configuration: {e}")

def handle_chart(ticker_symbol, period="1mo", interval="1d", is_candle=False):
    try:
        ticker = yf.Ticker(ticker_symbol)
        history = ticker.history(period=period, interval=interval)
        
        if history.empty:
            print(f"{C_RED}ERROR:{C_RESET} No historical data found for {ticker_symbol} with period={period} and interval={interval}")
            return

        chart_type = 'candle' if is_candle else 'line'
        title = f"{ticker_symbol} - {chart_type.capitalize()} Chart ({period}, {interval})"
        
        # Define chart style
        style = mpf.make_mpf_style(base_mpf_style='charles', gridstyle='', facecolor='black', edgecolor='white')
        
        # Prepare kwargs for mpf.plot
        plot_kwargs = {
            'type': chart_type,
            'title': title,
            'style': 'charles',
            'volume': True,
            'tight_layout': True,
            'show_nontrading': False
        }
        
        # Only add MAV if we have enough data
        if not history.empty and len(history) >= 50:
            plot_kwargs['mav'] = (20, 50)
        elif not history.empty and len(history) >= 20:
            plot_kwargs['mav'] = (20,)
            
        # Plot using mplfinance
        mpf.plot(history, **plot_kwargs)
        
    except Exception as e:
        print(f"{C_RED}ERROR:{C_RESET} Failed to generate chart: {e}")

def handle_order(ticker_symbol, action, qty, order_type="market", price=None):
    config = load_config()
    api_key = config.get('alpaca_key')
    api_secret = config.get('alpaca_secret')
    base_url = config.get('alpaca_base_url', 'https://paper-api.alpaca.markets')

    if not api_key or not api_secret:
        print(f"{C_RED}ERROR:{C_RESET} Alpaca API keys not found. Use --config set alpaca_key <key> and --config set alpaca_secret <secret>")
        return

    try:
        api = tradeapi.REST(api_key, api_secret, base_url, api_version='v2')
        order = api.submit_order(
            symbol=ticker_symbol.upper(),
            qty=qty,
            side=action,
            type=order_type,
            time_in_force='gtc',
            limit_price=price
        )
        print(f"{C_GREEN}ORDER SUBMITTED:{C_RESET} {action.upper()} {qty} shares of {ticker_symbol.upper()} ({order_type})")
        print(f"Order ID: {order.id} | Status: {order.status}")
    except Exception as e:
        print(f"{C_RED}ERROR:{C_RESET} Failed to submit order: {e}")

def main():
    parser = CustomArgumentParser(description="Global Linux Terminal Financial Command Engine", add_help=False)
    
    parser.add_argument("-h", "--help", action="store_true")
    parser.add_argument("ticker", nargs="?", help="Global stock exchange symbol token")
    parser.add_argument("--base", help="Target currency override ISO code")
    parser.add_argument("--json", action="store_true", help="Format response as raw JSON mapping objects")
    
    # Charting Options
    parser.add_argument("--chart", nargs="?", const="1mo", help="Render line chart for a period (e.g., 1d, 5d, 1mo, 1y)")
    parser.add_argument("--candle", nargs="?", const="1mo", help="Render candlestick chart for a period")
    parser.add_argument("--interval", default="1d", help="Interval for chart data (1m, 5m, 15m, 30m, 60m, 90m, 1h, 1d, 5d, 1wk, 1mo, 3mo)")
    
    # Trading Options
    parser.add_argument("--order", choices=['buy', 'sell'], help="Action for the order")
    parser.add_argument("--qty", type=float, help="Quantity of shares")
    parser.add_argument("--type", choices=['market', 'limit'], default="market", help="Order type")
    parser.add_argument("--price", type=float, help="Limit price for the order")
    
    # Config Options
    parser.add_argument("--config", nargs="+", help="Manage configuration (set key val, get key, delete key)")

    group = parser.add_mutually_exclusive_group()
    group.add_argument("--pull", choices=['all', 'market-cap', 'stock-price', 'dividend-yield', 'total-debt'])
    group.add_argument("--calc", choices=['all', 'fcf', 'dcf', 'ev', 'fcf-yield', 'multiples'])

    args = parser.parse_args()

    # Handle Config
    if args.config:
        config = load_config()
        action = args.config[0]
        if action == "set" and len(args.config) == 3:
            config[args.config[1]] = args.config[2]
            save_config(config)
        elif action == "get" and len(args.config) == 2:
            print(f"{args.config[1]}: {config.get(args.config[1], 'NOT SET')}")
        elif action == "delete" and len(args.config) == 2:
            if args.config[1] in config:
                del config[args.config[1]]
                save_config(config)
                print(f"Deleted {args.config[1]}")
        else:
            print(f"{C_RED}ERROR:{C_RESET} Invalid config command. Use: set <key> <val>, get <key>, or delete <key>")
        sys.exit(0)

    if args.help or (not args.ticker and not args.config):
        print_custom_help()
        sys.exit(0)

    if not args.ticker:
        print(f"{C_RED}ERROR:{C_RESET} Ticker symbol required for this operation.")
        sys.exit(1)

    if args.order:
        if args.qty is None:
            print(f"{C_RED}ERROR:{C_RESET} --qty is required for orders.")
            sys.exit(1)
        handle_order(args.ticker, args.order, args.qty, args.type, args.price)
        sys.exit(0)

    if args.chart or args.candle:
        handle_chart(args.ticker, args.chart or args.candle, args.interval, is_candle=bool(args.candle))
        sys.exit(0)

    if not args.pull and not args.calc:
        print_custom_help()
        sys.exit(0)

    data = get_ticker_data(args.ticker, args.base)
    if args.pull:
        handle_pull(args, data)
    elif args.calc:
        handle_calc(args, data)

if __name__ == "__main__":
    main()
