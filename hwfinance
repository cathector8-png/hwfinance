def generate_seed_phrase():
    """Generate 12 BIP39 words from 128 bits of cryptographic entropy."""
    import secrets
    entropy = int.from_bytes(secrets.token_bytes(16), 'big')  # 128 bits
    words = []
    for _ in range(12):
        words.append(BIP39_WORDLIST[entropy % len(BIP39_WORDLIST)])
        entropy //= len(BIP39_WORDLIST)
    return words

def mnemonic_to_fernet_key(words):
    """Derive a Fernet (AES-128-CBC + HMAC-SHA256) key from the 12-word phrase."""
    mnemonic = ' '.join(w.lower() for w in words)
    raw_key = hashlib.pbkdf2_hmac('sha256', mnemonic.encode('utf-8'), VAULT_SALT_AES, 200000)
    return base64.urlsafe_b64encode(raw_key)  # Fernet requires urlsafe-base64 32-byte key

def mnemonic_to_bucket_id(words):
    """Derive a deterministic, anonymous bucket ID from the 12-word phrase."""
    mnemonic = ' '.join(w.lower() for w in words)
    h = hashlib.sha256((mnemonic + VAULT_SALT_BUCKET).encode('utf-8')).hexdigest()
    return h[:40]  # 40-char hex string: 160-bit address space

def push_vault(bucket_id, encrypted_token_bytes):
    """Upload encrypted credentials to anonymous kvdb.io key-value store."""
    url = f"{KVDB_BASE}/{bucket_id}/hwf"
    req = urllib.request.Request(
        url, data=encrypted_token_bytes, method='POST',
        headers={'Content-Type': 'application/octet-stream', 'User-Agent': 'hwfinance/1.5'}
    )
    with urllib.request.urlopen(req, timeout=12) as r:
        return r.status in (200, 201)

def fetch_vault(bucket_id):
    """Download encrypted credentials from kvdb.io."""
    url = f"{KVDB_BASE}/{bucket_id}/hwf"
    req = urllib.request.Request(url, headers={'User-Agent': 'hwfinance/1.5'})
    with urllib.request.urlopen(req, timeout=12) as r:
        return r.read()

def handle_generate_seed(args):
    """Generate a 12-word seed phrase, encrypt local credentials, and push to cloud vault."""
    try:
        from cryptography.fernet import Fernet
    except ImportError:
        print(f"{C_RED}ERROR:{C_RESET} The 'cryptography' package is required for seed phrases.")
        print(f"  Install it with: {C_WHITE}pip install cryptography{C_RESET}")
        return

    config = load_config()
    api_key    = os.environ.get('APCA_API_KEY_ID') or config.get('alpaca_key', '')
    api_secret = os.environ.get('APCA_API_SECRET_KEY') or config.get('alpaca_secret', '')
    api_url    = os.environ.get('APCA_API_BASE_URL') or config.get('alpaca_base_url', 'https://paper-api.alpaca.markets')

    if not api_key or not api_secret:
        print(f"{C_RED}ERROR:{C_RESET} No Alpaca credentials found. Set them first:")
        print(f"  {C_WHITE}hwfinance --config set alpaca_key <KEY>{C_RESET}")
        print(f"  {C_WHITE}hwfinance --config set alpaca_secret <SECRET>{C_RESET}")
        return

    words     = generate_seed_phrase()
    fernet_key = mnemonic_to_fernet_key(words)
    bucket_id  = mnemonic_to_bucket_id(words)

    payload   = json.dumps({'alpaca_key': api_key, 'alpaca_secret': api_secret, 'alpaca_base_url': api_url})
    encrypted = Fernet(fernet_key).encrypt(payload.encode())

    print(f"\n{C_YELLOW}Uploading encrypted vault...{C_RESET}")
    try:
        push_vault(bucket_id, encrypted)
    except Exception as e:
        print(f"{C_RED}ERROR:{C_RESET} Failed to push vault: {e}")
        return

    config['seed_bucket_id'] = bucket_id
    save_config(config)

    # Display the seed phrase
    print(f"\n{C_GREEN}+-----------------------------------------------------------------------+")
    print(f"| {C_BOLD}YOUR HWFINANCE SEED PHRASE{C_RESET}{C_GREEN}                                              |")
    print(f"+-----------------------------------------------------------------------+{C_RESET}")
    print(f"\n{C_YELLOW}{C_BOLD}  Write down these 12 words in order. They are the ONLY way to recover your")
    print(f"  portfolio credentials on a new machine. Store them offline and securely.{C_RESET}\n")
    for i, word in enumerate(words, 1):
        bullet = f"{C_CYAN}{i:>2}.{C_RESET}"
        print(f"       {bullet}  {C_WHITE}{C_BOLD}{word:<14}{C_RESET}")
        if i == 6:
            print()
    print(f"\n{C_GREEN}+-----------------------------------------------------------------------+{C_RESET}")
    print(f"\n{C_BOLD}To sign in on any machine:{C_RESET}")
    print(f"  {C_CYAN}hwfinance log-in {' '.join(words)}{C_RESET}")
    print(f"\n{C_RED}⚠  WARNING: Anyone with these 12 words can access your Alpaca API credentials.{C_RESET}\n")

def handle_login(word_list):
    """Restore Alpaca credentials from a 12-word seed phrase via the cloud vault."""
    try:
        from cryptography.fernet import Fernet, InvalidToken
    except ImportError:
        print(f"{C_RED}ERROR:{C_RESET} The 'cryptography' package is required for seed phrases.")
        print(f"  Install it with: {C_WHITE}pip install cryptography{C_RESET}")
        sys.exit(1)

    if len(word_list) != 12:
        print(f"{C_RED}ERROR:{C_RESET} Exactly 12 seed words required. Got {len(word_list)}.")
        print(f"  Usage: {C_WHITE}hwfinance log-in word1 word2 ... word12{C_RESET}")
        sys.exit(1)

    words   = [w.lower().strip() for w in word_list]
    invalid = [w for w in words if w not in BIP39_WORDLIST]
    if invalid:
        print(f"{C_RED}ERROR:{C_RESET} Unrecognised seed word(s): {C_WHITE}{', '.join(invalid)}{C_RESET}")
        print(f"  All 12 words must come from the BIP39 English wordlist.")
        sys.exit(1)

    fernet_key = mnemonic_to_fernet_key(words)
    bucket_id  = mnemonic_to_bucket_id(words)

    print(f"\n{C_CYAN}Connecting to vault...{C_RESET}")
    try:
        encrypted_data = fetch_vault(bucket_id)
    except Exception as e:
        print(f"{C_RED}ERROR:{C_RESET} Could not reach the vault. Check your connection or seed words.")
        print(f"  Detail: {e}")
        sys.exit(1)

    try:
        decrypted = Fernet(fernet_key).decrypt(encrypted_data)
        creds     = json.loads(decrypted.decode())
    except InvalidToken:
        print(f"{C_RED}ERROR:{C_RESET} Decryption failed — incorrect seed phrase.")
        sys.exit(1)
    except Exception as e:
        print(f"{C_RED}ERROR:{C_RESET} Failed to decode vault data: {e}")
        sys.exit(1)

    config = load_config()
    config['alpaca_key']      = creds.get('alpaca_key', '')
    config['alpaca_secret']   = creds.get('alpaca_secret', '')
    config['alpaca_base_url'] = creds.get('alpaca_base_url', 'https://paper-api.alpaca.markets')
    config['seed_bucket_id']  = bucket_id
    save_config(config)

    key_preview = config['alpaca_key'][:8] + '...' if config['alpaca_key'] else 'N/A'
    url_display = config['alpaca_base_url']
    live = 'LIVE' if 'paper' not in url_display else 'PAPER'
    live_color = C_RED if live == 'LIVE' else C_YELLOW

    print(f"{C_GREEN}\n✓ Portfolio unlocked successfully.{C_RESET}")
    print(f"  Alpaca Key:  {C_WHITE}{key_preview}{C_RESET}")
    print(f"  Mode:        {live_color}{C_BOLD}{live}{C_RESET}")
    print(f"  Base URL:    {C_WHITE}{url_display}{C_RESET}\n")

def handle_order(ticker_symbol, action, qty, order_type="market", price=None, skip_confirm=False):
    config = load_config()
    api_key = os.environ.get('APCA_API_KEY_ID') or os.environ.get('ALPACA_API_KEY_ID') or config.get('alpaca_key')
    api_secret = os.environ.get('APCA_API_SECRET_KEY') or os.environ.get('ALPACA_API_SECRET_KEY') or config.get('alpaca_secret')
    base_url = os.environ.get('APCA_API_BASE_URL') or os.environ.get('ALPACA_API_BASE_URL') or config.get('alpaca_base_url', 'https://paper-api.alpaca.markets')

    if not api_key or not api_secret:
        print(f"{C_RED}ERROR:{C_RESET} Alpaca API credentials not found.")
        print("Set them via environment variables (APCA_API_KEY_ID & APCA_API_SECRET_KEY)")
        print("or run config: hwfinance --config set alpaca_key <KEY> and alpaca_secret <SECRET>")
        return

    price_val = price
    currency = 'USD'
    cs = '$'
    try:
        data = get_ticker_data(ticker_symbol)
        if not price_val:
            price_val = data['price']
        currency = data['native_currency']
        cs = data['currency_symbol']
    except Exception:
        pass

    est_cost = (price_val * qty) if price_val else 0.0

    if not skip_confirm and sys.stdin.isatty():
        print(f"\n{C_YELLOW}{C_BOLD}⚠️  TRADE ORDER CONFIRMATION{C_RESET}")
        print(f"  Ticker:     {C_CYAN}{ticker_symbol.upper()}{C_RESET}")
        print(f"  Action:     {C_GREEN if action == 'buy' else C_RED}{action.upper()}{C_RESET}")
        print(f"  Quantity:   {C_WHITE}{qty}{C_RESET}")
        print(f"  Order Type: {C_WHITE}{order_type.upper()}{C_RESET}")
        if price_val:
            print(f"  Price:      {C_WHITE}{cs}{price_val:,.2f} {currency}{C_RESET}")
            print(f"  Est. Cost:  {C_WHITE}{cs}{est_cost:,.2f} {currency}{C_RESET}")
        else:
            print(f"  Price:      {C_WHITE}Market price (unknown){C_RESET}")
        
        try:
            confirm = input(f"\nProceed with submitting this order to Alpaca? [y/N]: ").strip().lower()
            if confirm not in ['y', 'yes']:
                print(f"{C_RED}ORDER CANCELLED by user.{C_RESET}")
                return
        except (KeyboardInterrupt, EOFError):
            print(f"\n{C_RED}ORDER CANCELLED by user.{C_RESET}")
            return

    try:
        api = tradeapi.REST(api_key, api_secret, base_url, api_version='v2')
        order = api.submit_order(
            symbol=ticker_symbol.upper(),
            qty=qty,
            side=action,
            type=order_type,
            time_in_force='gtc',
            limit_price=price
        )
        print(f"{C_GREEN}ORDER SUBMITTED:{C_RESET} {action.upper()} {qty} shares of {ticker_symbol.upper()} ({order_type})")
        print(f"Order ID: {order.id} | Status: {order.status}")
    except Exception as e:
        print(f"{C_RED}ERROR:{C_RESET} Failed to submit order: {e}")

def search_ticker(query):
    url = f"https://query2.finance.yahoo.com/v1/finance/search?q={urllib.parse.quote(query)}"
    try:
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        with urllib.request.urlopen(req, timeout=5) as response:
            res = json.loads(response.read().decode())
            quotes = res.get('quotes', [])
            return [
                {
                    "symbol": q.get("symbol"),
                    "name": q.get("shortname") or q.get("longname") or "",
                    "exchange": q.get("exchange") or "",
                    "type": q.get("quoteType") or ""
                }
                for q in quotes if "symbol" in q
            ]
    except Exception:
        return []

def handle_ticker_not_found(ticker_symbol):
    print(f"{C_YELLOW}Ticker '{ticker_symbol}' not found or failed to load.{C_RESET}")
    if not sys.stdin.isatty() or not sys.stdout.isatty():
        return None
    
    print(f"Searching for '{ticker_symbol}'...")
    matches = search_ticker(ticker_symbol)
    if not matches:
        print(f"{C_RED}No matching tickers found.{C_RESET}")
        return None
        
    print(f"\n{C_CYAN}Matching symbols:{C_RESET}")
    limit = min(len(matches), 8)
    for idx in range(limit):
        match = matches[idx]
        print(f"  [{idx + 1}] {C_BOLD}{match['symbol']}{C_RESET} - {match['name']} ({match['exchange']} / {match['type']})")
    
    try:
        val = input(f"\nSelect a ticker by number (1-{limit}) or press Enter to cancel: ").strip()
        if not val:
            return None
        idx = int(val)
        if 1 <= idx <= limit:
            return matches[idx - 1]['symbol']
    except (ValueError, IndexError):
        print(f"{C_RED}Invalid selection.{C_RESET}")
    except (KeyboardInterrupt, EOFError):
        print()
    return None

def handle_text_chart(ticker_symbol, period="1mo", interval="1d", is_candle=False):
    try:
        ticker = yf.Ticker(ticker_symbol)
        history = ticker.history(period=period, interval=interval)
        if history.empty:
            print(f"{C_RED}ERROR:{C_RESET} No historical data found for {ticker_symbol} with period={period} and interval={interval}")
            return
        
        try:
            terminal_cols = os.get_terminal_size().columns
        except OSError:
            terminal_cols = 80
            
        width = min(len(history), terminal_cols - 15)
        if width < 10:
            width = len(history)
        height = 12
        
        indices = [int(i * (len(history) - 1) / (width - 1)) for i in range(width)]
        df_plot = history.iloc[indices]
        
        min_y = df_plot['Low'].min() if is_candle else df_plot['Close'].min()
        max_y = df_plot['High'].max() if is_candle else df_plot['Close'].max()
        if min_y == max_y:
            min_y -= 1.0
            max_y += 1.0
            
        def to_r(val):
            return max(0, min(height - 1, int(round((max_y - val) / (max_y - min_y) * (height - 1)))))
            
        grid = [[" " for _ in range(width)] for _ in range(height)]
        colors = [[C_RESET for _ in range(width)] for _ in range(height)]
        
        if is_candle:
            for c in range(width):
                row = df_plot.iloc[c]
                ro = to_r(row['Open'])
                rc = to_r(row['Close'])
                rh = to_r(row['High'])
                rl = to_r(row['Low'])
                
                color = C_GREEN if row['Close'] >= row['Open'] else C_RED
                
                for r in range(min(rh, rl), max(rh, rl) + 1):
                    grid[r][c] = "│"
                    colors[r][c] = color
                
                for r in range(min(ro, rc), max(ro, rc) + 1):
                    grid[r][c] = "█"
                    colors[r][c] = color
                    
                if ro == rc:
                    grid[ro][c] = "─"
                    colors[ro][c] = color
        else:
            for c in range(width):
                row = df_plot.iloc[c]
                rc = to_r(row['Close'])
                grid[rc][c] = "●"
                colors[rc][c] = C_CYAN
                for r in range(rc + 1, height):
                    grid[r][c] = "░"
                    colors[r][c] = "\033[2;36m"
                    
        chart_type = "Candlestick" if is_candle else "Line"
        print(f"\n{C_GREEN}+-----------------------------------------------------------+")
        print(f"| {C_BOLD}{ticker_symbol.upper()} - Text {chart_type} Chart ({period}, {interval}){C_RESET}{C_GREEN:<16} |")
        print(f"+-----------------------------------------------------------+{C_RESET}\n")
        
        for r in range(height):
            price_val = max_y - r * (max_y - min_y) / (height - 1)
            label = f"{price_val:10.2f} │"
            row_str = "".join(f"{colors[r][c]}{grid[r][c]}{C_RESET}" for c in range(width))
            print(f"{C_CYAN}{label}{C_RESET} {row_str}")
            
        axis_line = "─" * width
        print(f"{C_CYAN}{' ':10} └{axis_line}{C_RESET}")
        
        dates = df_plot.index
        d_start = dates[0].strftime('%Y-%m-%d')
        d_end = dates[-1].strftime('%Y-%m-%d')
        d_mid = dates[len(dates)//2].strftime('%Y-%m-%d')
        
        mid_pos = width // 2 - len(d_mid) // 2
        end_pos = width - len(d_end)
        
        timeline = list(" " * width)
        if width > len(d_start) + len(d_mid) + len(d_end) + 4:
            timeline[0:len(d_start)] = list(d_start)
            timeline[mid_pos:mid_pos+len(d_mid)] = list(d_mid)
            timeline[end_pos:end_pos+len(d_end)] = list(d_end)
        else:
            timeline[0:len(d_start)] = list(d_start)
            if width > len(d_start) + len(d_end) + 2:
                timeline[end_pos:end_pos+len(d_end)] = list(d_end)
                
        print(f"{' ':12}{C_WHITE}{''.join(timeline)}{C_RESET}\n")
        
    except Exception as e:
        print(f"{C_RED}ERROR:{C_RESET} Failed to generate text chart: {e}")

def format_output(headers, rows, alignments, fmt="table"):
    if fmt == "csv":
        print(",".join(f'"{h}"' if ',' in str(h) else str(h) for h in headers))
        for row in rows:
            clean_row = [re.sub(r'\033\[[0-9;]*m', '', str(val)) for val in row]
            print(",".join(f'"{val}"' if ',' in str(val) else str(val) for val in clean_row))
    elif fmt == "tsv":
        print("\t".join(str(h) for h in headers))
        for row in rows:
            clean_row = [re.sub(r'\033\[[0-9;]*m', '', str(val)) for val in row]
            print("\t".join(str(val) for val in clean_row))
    elif fmt == "markdown":
        print("| " + " | ".join(headers) + " |")
        align_row = []
        for align in alignments:
            if align == 'R':
                align_row.append("---:")
            else:
                align_row.append("---")
        print("| " + " | ".join(align_row) + " |")
        for row in rows:
            clean_row = [re.sub(r'\033\[[0-9;]*m', '', str(val)) for val in row]
            print("| " + " | ".join(clean_row) + " |")
    else:
        widths = [len(h) for h in headers]
        for row in rows:
            for i, val in enumerate(row):
                clean_val = re.sub(r'\033\[[0-9;]*m', '', str(val))
                widths[i] = max(widths[i], len(clean_val))
        
        border = "+" + "-".join("-" * (w + 2) for w in widths) + "+"
        print(C_GREEN + border + C_RESET)
        header_cols = []
        for i, h in enumerate(headers):
            align = alignments[i]
            if align == 'R':
                header_cols.append(f"{C_WHITE}{str(h):>{widths[i]}}{C_RESET}")
            else:
                header_cols.append(f"{C_WHITE}{str(h):<{widths[i]}}{C_RESET}")
        print(C_GREEN + "| " + C_RESET + (C_GREEN + " | " + C_RESET).join(header_cols) + C_GREEN + " |" + C_RESET)
        print(C_GREEN + border + C_RESET)
        for row in rows:
            row_cols = []
            for i, val in enumerate(row):
                align = alignments[i]
                clean_val = re.sub(r'\033\[[0-9;]*m', '', str(val))
                padding = widths[i] - len(clean_val)
                if align == 'R':
                    row_cols.append(" " * padding + f"{str(val)}")
                else:
                    row_cols.append(f"{str(val)}" + " " * padding)
            print(C_GREEN + "| " + C_RESET + (C_GREEN + " | " + C_RESET).join(row_cols) + C_GREEN + " |" + C_RESET)
        print(C_GREEN + border + C_RESET)

