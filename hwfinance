def run_config(config_args):
    config = load_config()
    action = config_args[0]
    if action == "set" and len(config_args) == 3:
        config[config_args[1]] = config_args[2]
        save_config(config)
    elif action == "get" and len(config_args) == 2:
        print(f"{config_args[1]}: {config.get(config_args[1], 'NOT SET')}")
    elif action == "delete" and len(config_args) == 2:
        if config_args[1] in config:
            del config[config_args[1]]
            save_config(config)
            print(f"Deleted {config_args[1]}")
    else:
        print(f"{C_RED}ERROR:{C_RESET} Invalid config command. Use: set <key> <val>, get <key>, or delete <key>")

def run_command_logic(args, parser=None):
    if args.portfolio or args.account:
        handle_portfolio_and_account(args)
        return
        
    if args.config:
        run_config(args.config)
        return

    if not args.ticker:
        if not sys.stdin.isatty():
            try:
                stdin_content = sys.stdin.read()
                args.ticker = [t.strip() for t in re.split(r'\s+', stdin_content) if t.strip()]
            except Exception:
                pass

    if not args.ticker:
        print(f"{C_RED}ERROR:{C_RESET} Ticker symbol required for this operation.")
        return

    if args.order:
        if args.qty is None:
            print(f"{C_RED}ERROR:{C_RESET} --qty is required for orders.")
            return
        handle_order(args.ticker[0], args.order, args.qty, args.type, args.price, skip_confirm=args.yes)
        return

    if args.chart or args.candle:
        is_headless = 'DISPLAY' not in os.environ or not os.environ['DISPLAY']
        use_text_chart = args.text_chart or is_headless
        if use_text_chart:
            handle_text_chart(args.ticker[0], args.chart or args.candle, args.interval, is_candle=bool(args.candle))
        else:
            handle_chart(args.ticker[0], args.chart or args.candle, args.interval, is_candle=bool(args.candle))
        return

    if not args.pull and not args.calc:
        if parser:
            parser.print_usage()
        else:
            print_custom_help()
        return

    results = []
    for t in args.ticker:
        data = None
        try:
            data = get_ticker_data(t, args.base)
            if data and data['price'] == 0.0 and data['market_cap'] == 0.0:
                raise ValueError("Empty ticker data")
        except Exception:
            better_ticker = handle_ticker_not_found(t)
            if better_ticker:
                try:
                    data = get_ticker_data(better_ticker, args.base)
                except Exception as retry_err:
                    print(f"{C_RED}ERROR:{C_RESET} Failed to fetch data for resolved ticker {better_ticker}: {retry_err}")
            else:
                print(f"{C_RED}ERROR:{C_RESET} Could not fetch data for ticker: {t}")
        
        if data:
            results.append(data)
            
    if not results:
        print(f"{C_RED}ERROR:{C_RESET} No data retrieved.")
        return

    if args.json:
        if len(results) == 1:
            print(json.dumps(results[0], indent=4))
        else:
            print(json.dumps(results, indent=4))
        return

    if len(results) == 1 and args.format == "table":
        if args.pull:
            handle_pull(args, results[0])
        elif args.calc:
            handle_calc(args, results[0])
    else:
        if args.pull:
            handle_pull_multiple(args, results)
        elif args.calc:
            handle_calc_multiple(args, results)

def handle_shell(parser):
    import shlex
    print(f"\n{C_GREEN}Welcome to {C_BOLD}hwfinance{C_RESET}{C_GREEN} Interactive Shell!{C_RESET}")
    print(f"Type {C_CYAN}help{C_RESET} to show the help manual, or {C_CYAN}exit{C_RESET} or {C_CYAN}quit{C_RESET} to leave.\n")
    
    while True:
        try:
            line = input(f"{C_GREEN}hwfinance> {C_RESET}").strip()
            if not line:
                continue
            if line.lower() in ['exit', 'quit', 'q']:
                print("Exiting...")
                break
                
            tokens = shlex.split(line)
            if tokens and tokens[0] == 'hwfinance':
                tokens = tokens[1:]
                
            if not tokens:
                continue
                
            if tokens == ['help'] or tokens == ['-h'] or tokens == ['--help']:
                print_custom_help()
                continue
                
            original_error = parser.error
            original_exit = parser.exit
            
            parse_failed = [False]
            def shell_error(message):
                print(f"{C_RED}ERROR:{C_RESET} {message}")
                parse_failed[0] = True
                
            def shell_exit(status=0, message=None):
                if message:
                    print(message)
                parse_failed[0] = True
                
            parser.error = shell_error
            parser.exit = shell_exit
            
            try:
                sub_args = parser.parse_args(tokens)
            except SystemExit:
                sub_args = None
                
            parser.error = original_error
            parser.exit = original_exit
            
            if parse_failed[0] or sub_args is None:
                continue
                
            if sub_args.help:
                print_custom_help()
                continue
                
            run_command_logic(sub_args, parser)
            
        except (KeyboardInterrupt, EOFError):
            print("\nExiting...")
            break
        except Exception as e:
            print(f"{C_RED}Unexpected Error in shell:{C_RESET} {e}")

def main():
    # ── Handle 'log-in' before argparse so the hyphen doesn't confuse it ───────
    if len(sys.argv) > 1 and sys.argv[1] == 'log-in':
        handle_login(sys.argv[2:])
        sys.exit(0)

    parser = CustomArgumentParser(description="Global Linux Terminal Financial Command Engine", add_help=False)
    
    parser.add_argument("-h", "--help", action="store_true")
    parser.add_argument("ticker", nargs="*", help="Global stock exchange symbol token(s)")
    parser.add_argument("--base", help="Target currency override ISO code")
    parser.add_argument("--json", action="store_true", help="Format response as raw JSON mapping objects")
    
    # Charting Options
    parser.add_argument("--chart", nargs="?", const="1mo", help="Render line chart for a period")
    parser.add_argument("--candle", nargs="?", const="1mo", help="Render candlestick chart for a period")
    parser.add_argument("--interval", default="1d", help="Interval for chart data (1m, 5m, 15m, 30m, 60m, 90m, 1h, 1d, 5d, 1wk, 1mo, 3mo)")
    parser.add_argument("-t", "--text-chart", action="store_true", help="Force text-based ASCII chart rendering")
    
    # Format Options
    parser.add_argument("-f", "--format", choices=["table", "csv", "tsv", "markdown"], default="table", help="Tabular output format")
    
    # Trading Options
    parser.add_argument("--order", choices=['buy', 'sell'], help="Action for the order")
    parser.add_argument("--qty", type=float, help="Quantity of shares")
    parser.add_argument("--type", choices=['market', 'limit'], default="market", help="Order type")
    parser.add_argument("--price", type=float, help="Limit price for the order")
    parser.add_argument("-y", "--yes", action="store_true", help="Bypass order confirmation prompt")
    parser.add_argument("--portfolio", action="store_true", help="Display portfolio positions")
    parser.add_argument("--account", action="store_true", help="Display account summary")
    
    # Shell REPL
    parser.add_argument("-i", "--shell", action="store_true", help="Start interactive shell REPL")

    # Seed Phrase
    parser.add_argument("--generate-seed", action="store_true",
                        help="Generate a 12-word seed phrase and push encrypted credentials to a cloud vault")

    # Config Options
    parser.add_argument("--config", nargs="+", help="Manage configuration (set key val, get key, delete key)")

    group = parser.add_mutually_exclusive_group()
    group.add_argument("--pull", choices=['all', 'market-cap', 'stock-price', 'dividend-yield', 'total-debt'])
    group.add_argument("--calc", choices=['all', 'fcf', 'dcf', 'ev', 'fcf-yield', 'multiples'])

    args = parser.parse_args()

    # Help handler
    if args.help:
        print_custom_help()
        sys.exit(0)

    # Seed phrase generation
    if args.generate_seed:
        handle_generate_seed(args)
        sys.exit(0)

    # Shell handler
    if args.shell:
        handle_shell(parser)
        sys.exit(0)

    # Fallback to shell if interactive and no action/ticker/config specified
    is_action = bool(args.config or args.order or args.chart or args.candle or args.pull or args.calc or args.portfolio or args.account)
    if not args.ticker and not is_action:
        if sys.stdin.isatty():
            handle_shell(parser)
            sys.exit(0)
        else:
            print_custom_help()
            sys.exit(0)

    # Normal execution path
    run_command_logic(args, parser)

if __name__ == "__main__":
    main()
